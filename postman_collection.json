					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Script para capturar el token automáticamente después del login",
					"if (pm.response.code === 200 || pm.response.code === 201) {",
					"    var jsonData = pm.response.json();",
					"    if (jsonData.datos && jsonData.datos.token) {",
					"        pm.environment.set(\"token\", jsonData.datos.token);",
					"    }",
					"}"
				]
			}
		}
	],
